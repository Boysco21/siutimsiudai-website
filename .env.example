# ---------------------------------------------------------------------------
# Sik Fan (食飯) — client environment template.
# Copy this to a local .env (which is gitignored) and fill in real values:
#     cp .env.example .env
#
# ONLY EXPO_PUBLIC_* values belong in this file. Expo inlines every EXPO_PUBLIC_
# variable into the app bundle at build time, so treat them all as PUBLIC.
# Never put a billable secret here (Google API key, RevenueCat sk_ secret key,
# Supabase service_role key) — it would ship on every user's device.
# ---------------------------------------------------------------------------

# RevenueCat — Apple *publishable* SDK key only (safe to ship). Never the sk_ secret.
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase — project URL + *anon* (publishable) key only. Never the service_role key.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# ---------------------------------------------------------------------------
# The Google Cloud Translation key is a BILLABLE SECRET and does NOT go here.
# It lives server-side only, set on the Supabase Edge Function:
#
#     supabase secrets set GOOGLE_TRANSLATE_API_KEY=AIza...your-key...
#     supabase functions deploy translate
#
# The app calls the "translate" Edge Function over HTTPS; the key never reaches
# a device. See supabase/functions/translate/index.ts.
# ---------------------------------------------------------------------------
